# ==========================================
# PetCare 后端环境变量配置
# 复制此文件为 .env 并填入实际值
# ==========================================

# Supabase PostgreSQL 连接配置
# 使用 Session Pooler 连接字符串（端口 5432）
# 格式：postgresql://postgres.[项目REF]:[数据库密码]@[主机]:5432/postgres
# 在 Supabase Dashboard → Settings → Database → Connection string 中获取
DATABASE_URL=postgresql://postgres.adnukbhgllpkzonhvajt:Cwxh@123Cwxh@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# Supabase API 配置（前端使用）
# 在 Supabase Dashboard → Settings → API 中获取
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 服务端口
PORT=3001

# 环境标识
NODE_ENV=development
VITE_API_BASE=http://localhost:3001/api
